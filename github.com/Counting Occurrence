import java.util.Scanner;
public class CountingOccurrence{
public static void main (String [] args) {
  Scanner in = new Scanner (System.in);
int count = 0;
int fn = in.nextInt();
int Sn = in.nextInt();
while (fn > 0) {
int rem = fn % 10;
if (rem == Sn ) {
    count++;
}
fn = fn/10;
}
System.out.println(count);
}
